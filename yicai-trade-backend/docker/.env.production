# ============================================
# 易采贸易平台 - 生产环境配置
# ============================================
# 使用方法: 复制此文件为 .env 并填写实际值
# cp .env.production .env
# 然后编辑 .env 填写你的实际配置
# ============================================

# ---- 数据库配置 (阿里云RDS MySQL) ----
DB_HOST=你的RDS内网地址
DB_PORT=3306
DB_NAME=yicai_trade
DB_USERNAME=yicai_admin
DB_PASSWORD=你的数据库密码

# ---- Redis配置 ----
# 留空表示不设置密码(Docker内网Redis)
REDIS_PASSWORD=

# ---- JWT安全密钥 ----
# 至少64字符的随机字符串，用于签名JWT令牌
JWT_SECRET=请替换为一个至少64字符的随机安全密钥

# ---- CORS跨域配置 ----
# 生产环境建议设置为具体域名，如 http://47.243.41.206
# 多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=*

# ---- AI模型API密钥 ----
# 豆包视觉模型 (图片识别)
DOUBAO_VISION_KEY=你的豆包视觉API密钥
# 豆包文本模型 (品类匹配)
DOUBAO_TEXT_KEY=你的豆包文本API密钥
# 智谱模型 (成本计算)
ZHIPU_KEY=你的智谱API密钥
# DeepSeek模型 (AI助手)
DEEPSEEK_KEY=你的DeepSeek API密钥

# ---- AI模型ID (如需覆盖默认值) ----
# DOUBAO_VISION_MODEL=idep-20260215104814-x5t6l
# DOUBAO_TEXT_MODEL=ep-20260217114227-lm9vr
# ZHIPU_MODEL=ep-20260217114008-h7cxp
# DEEPSEEK_MODEL=ep-20260308122419-6cf68

# ---- 物流查询API (阿里云API市场) ----
LOGISTICS_APP_CODE=你的物流查询AppCode

# ---- 短信验证码API (阿里云API市场 - 望为科技) ----
SMS_APP_CODE=你的短信服务AppCode
SMS_API_URL=https://wwsms.market.alicloudapi.com/send_sms
SMS_TEMPLATE_ID=wangweisms996
SMS_ENABLED=true

# ---- 邮件服务配置 (SMTP) ----
EMAIL_ENABLED=false
EMAIL_FROM_NAME=易采贸易平台
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=你的邮箱地址
MAIL_PASSWORD=你的邮箱授权码

# ---- 微信开放平台 ----
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENABLED=false
