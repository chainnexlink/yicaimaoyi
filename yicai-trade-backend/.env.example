# 易采贸易平台环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库配置 (阿里云PolarDB)
DB_HOST=pc-2ze026hgqyp8va32u.polardb.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=yicai_trade
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置 (请生成一个至少64位的随机字符串)
JWT_SECRET=yicai-trade-platform-jwt-secret-key-change-this-in-production-env

# Spring配置
SPRING_PROFILES_ACTIVE=dev

# CORS允许的域名（生产环境必须配置，多个用逗号分隔）
# 示例: CORS_ALLOWED_ORIGINS=https://www.yicai-trade.com,https://admin.yicai-trade.com
CORS_ALLOWED_ORIGINS=*

# AI模型API密钥（可选，如需使用AI智能匹配功能）
DOUBAO_VISION_KEY=
DOUBAO_TEXT_KEY=
ZHIPU_KEY=

# 物流查询API（阿里云API市场 - 全球快递物流查询）
LOGISTICS_APP_CODE=
