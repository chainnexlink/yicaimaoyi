// 获取当前语言
function getCurrentLanguage() {
    return localStorage.getItem('platform_language') || 'zh';
}

// 设置当前语言
function setCurrentLanguage(lang) {
    localStorage.setItem('platform_language', lang);
}

// 切换语言
function switchLanguage(lang) {
    if (!languages[lang]) return;

    setCurrentLanguage(lang);
    updateLanguageUI(lang);
    updatePageContent(lang);

    // 更新下拉菜单中的选中状态
    document.querySelectorAll('.lang-option').forEach(option => {
        option.classList.remove('active');
        if (option.dataset.lang === lang) {
            option.classList.add('active');
        }
    });
}

// 更新语言选择器UI
function updateLanguageUI(lang) {
    const langData = languages[lang];
    const currentLangEl = document.getElementById('currentLang');
    if (currentLangEl) {
        currentLangEl.textContent = langData.name;
    }

    // 更新所有页面上的语言选择器
    document.querySelectorAll('.current-lang').forEach(el => {
        el.textContent = langData.name;
    });
}

// 更新页面内容（基于 data-i18n 属性）
function updatePageContent(lang) {
    const translations = languages[lang].translations;

    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.dataset.i18n;
        if (translations[key]) {
            if (el.tagName === 'INPUT' && el.type !== 'submit' && el.type !== 'button') {
                el.placeholder = translations[key];
            } else if (el.tagName === 'TITLE') {
                document.title = translations[key];
            } else {
                // 保留子元素（如 badge span），仅替换第一个文本节点
                const childElements = el.querySelectorAll('*');
                if (childElements.length > 0) {
                    // 找到第一个文本节点并替换
                    let found = false;
                    for (let i = 0; i < el.childNodes.length; i++) {
                        if (el.childNodes[i].nodeType === Node.TEXT_NODE && el.childNodes[i].textContent.trim()) {
                            el.childNodes[i].textContent = translations[key] + ' ';
                            found = true;
                            break;
                        }
                    }
                    if (!found) {
                        el.insertBefore(document.createTextNode(translations[key] + ' '), el.firstChild);
                    }
                } else {
                    el.textContent = translations[key];
                }
            }
        }
    });
}

// 获取翻译文本
function t(key) {
    const lang = getCurrentLanguage();
    return languages[lang]?.translations[key] || key;
}

// 初始化语言
function initLanguage() {
    const currentLang = getCurrentLanguage();
    updateLanguageUI(currentLang);
    updatePageContent(currentLang);

    // 设置下拉菜单中的初始选中状态
    document.querySelectorAll('.lang-option').forEach(option => {
        option.classList.remove('active');
        if (option.dataset.lang === currentLang) {
            option.classList.add('active');
        }
    });
}

// 页面加载时初始化
document.addEventListener('DOMContentLoaded', initLanguage);
